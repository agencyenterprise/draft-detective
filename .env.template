# OpenAI (To use Azure's OpenAI, omit OPENAI_API_KEY and set all three of OPENAI_API_VERSION, AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_API_KEY)
OPENAI_API_KEY=
# OPENAI_API_VERSION=2023-06-01-preview  # or your api version
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
# AZURE_OPENAI_API_KEY=<your Azure OpenAI API key>

# Logging Configuration
LOG_RICH_HANDLER=true

# Langfuse
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_TRACING_ENVIRONMENT=local
LANGFUSE_PROJECT_ID=

# Langgraph Configuration
# LANGGRAPH_MAX_CONCURRENCY=30  # Maximum concurrent langgraph nodes (default: 30)

# Database Configuration
DATABASE_URL=postgresql://ai_reviewer_user:ai_reviewer_password@0.0.0.0:5432/ai_reviewer
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_reviewer
POSTGRES_USER=ai_reviewer_user
POSTGRES_PASSWORD=ai_reviewer_password

# Concurrency config
MAX_CONCURRENT_TASKS=20

# File upload
FILE_UPLOADS_MOUNT_PATH=uploads

AUTH_SECRET=

# Shareable links
FRONTEND_URL=http://localhost:3000
